# Schwab API
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1
SCHWAB_TOKEN_PATH=/app/schwab_token.json

# InfluxDB (running natively on Pi)
INFLUXDB_URL=http://host.docker.internal:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=options_trading
INFLUXDB_BUCKET=options_db

# PostgreSQL
POSTGRES_USER=trading
POSTGRES_PASSWORD=
POSTGRES_DB=trading
POSTGRES_URL=postgresql+asyncpg://trading:changeme@postgres:5432/trading

# Redis
REDIS_URL=redis://redis:6379

# Anthropic
ANTHROPIC_API_KEY=

# Ingestion
QUERY_INTERVAL=30
STRIKE_COUNT=10
DEFAULT_SYMBOLS=PANW,QCOM,CSCO
